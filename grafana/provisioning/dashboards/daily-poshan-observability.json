        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "http_server_active_requests{job=\"dailyposhan-backend\"}",
          "legendFormat": "active",
          "refId": "A"
        }
      ],
