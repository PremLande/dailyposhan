      "id": 5,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (http_status_code) (rate(http_server_duration_milliseconds_count{job=\"dailyposhan-backend\"}[5m]))",
          "legendFormat": "{{http_status_code}}",
          "refId": "A"
        }
      ],
      "title": "Requests by Status Code",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "id": 6,
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum by (http_target) (rate(http_server_duration_milliseconds_count{job=\"dailyposhan-backend\"}[5m]))",
          "legendFormat": "{{http_target}}",
          "refId": "A"
        }
      ],
      "title": "Requests by Endpoint",
